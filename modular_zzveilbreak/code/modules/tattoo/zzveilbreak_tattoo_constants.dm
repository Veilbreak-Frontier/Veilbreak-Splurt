// UI font sizes
#define UI_FONT_SIZE_SMALL "0.8em"
#define UI_FONT_SIZE_NORMAL "1em"
#define UI_FONT_SIZE_LARGE "1.2em"
#define UI_FONT_SIZE_HEADER "1.5em"

// Text area dimensions
#define TATTOO_DESIGN_WIDTH 300
#define TATTOO_DESIGN_HEIGHT 100
#define ARTIST_NAME_WIDTH 200

// Simple color brightness check - doesn't require hex2rgb
/proc/is_color_readable(color_string)
	if(!color_string)
		return FALSE

	// Simple check for very dark colors
	if(color_string == "#000000" || color_string == "#000" || color_string == "#111" || color_string == "#111111")
		return FALSE

	// Check for dark gray colors
	if(color_string == "#222" || color_string == "#222222" || color_string == "#333" || color_string == "#333333")
		return FALSE

	// Default to readable for other colors
	return TRUE

// Get safe ink color that ensures visibility
/proc/get_safe_ink_color(color_string)
	var/color = sanitize_hexcolor(color_string, default = "#404040")
	// Ensure minimum brightness for readability
	if(!is_color_readable(color))
		return "#404040" // Dark gray instead of pure black
	return color
